# =============================================================================
# Firecrawl — Self-hosted configuration
# Copiar a .env y ajustar si es necesario
# =============================================================================

# --- API ---
PORT=3002
HOST=0.0.0.0

# --- Workers ---
# Número de workers por cola. En un Mac con 8GB RAM, 4–8 es suficiente.
NUM_WORKERS_PER_QUEUE=8

# --- Redis ---
REDIS_URL=redis://redis:6379
REDIS_RATE_LIMIT_URL=redis://redis:6379

# --- Playwright ---
PLAYWRIGHT_MICROSERVICE_URL=http://playwright-service:3000

# --- Auth (self-hosted: no se valida, cualquier string funciona) ---
# Esta clave debe coincidir con FIRECRAWL_API_KEY en el MCP de Claude Code
FIRECRAWL_API_KEY=local

# --- Bull Queue Admin UI ---
# Accesible en http://localhost:3002/admin/${BULL_AUTH_KEY}/queues
BULL_AUTH_KEY=firecrawl-admin

# --- Logging ---
LOG_LEVEL=info

# --- Opcional: límites de scraping por dominio (comentar para sin límite) ---
# SCRAPING_BEE_API_KEY=
# OPENAI_API_KEY=
